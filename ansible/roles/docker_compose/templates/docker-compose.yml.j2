# Generated by Ansible — do not edit manually
---
services:
{% for item in docker_compose_services_sorted | dict2items | sort(attribute='value.priority', reverse=false) %}
{% set svc_name = item.key %}
{% set svc = item.value %}
{% if svc.type | default('') == 'infrastructure' %}
{% if svc_name == 'traefik' %}
{% include 'traefik.yml.j2' %}
{% elif svc_name == 'gluetun' %}
{% include 'gluetun.yml.j2' %}
{% endif %}
{% else %}
  {{ svc_name }}:
    image: {{ svc.image }}
    restart: unless-stopped
{% if svc.environment is defined %}
    environment:
{% for key, val in svc.environment.items() %}
      {{ key }}: "{{ val }}"
{% endfor %}
{% endif %}
{% if svc.network_mode is defined %}
    network_mode: "{{ svc.network_mode }}"
{% endif %}
{% if svc.depends_on is defined %}
    depends_on:
{% for dep_name, dep_config in svc.depends_on.items() %}
      {{ dep_name }}:
        condition: {{ dep_config.condition }}
{% endfor %}
{% endif %}
{% if svc.ports is defined and svc.network_mode is not defined %}
    ports:
{% for port in svc.ports %}
      - "{{ port }}"
{% endfor %}
{% endif %}
{% if svc.volumes is defined %}
    volumes:
{% for vol in svc.volumes %}
      - "{{ vol }}"
{% endfor %}
{% endif %}
{% if svc.healthcheck is defined %}
    healthcheck:
      test: {{ svc.healthcheck.test | to_json }}
      interval: {{ svc.healthcheck.interval }}
      timeout: {{ svc.healthcheck.timeout }}
      retries: {{ svc.healthcheck.retries }}
{% endif %}
{% if svc.traefik is defined and svc.traefik != false %}
    labels:
      - "traefik.enable=true"
{% if svc.traefik.routes is defined %}
{% for route in svc.traefik.routes %}
      - "traefik.http.routers.{{ svc_name }}-{{ loop.index0 }}.rule={{ route.rule }}"
      - "traefik.http.routers.{{ svc_name }}-{{ loop.index0 }}.entrypoints={{ route.entrypoint }}"
      - "traefik.http.routers.{{ svc_name }}-{{ loop.index0 }}.service={{ svc_name }}-{{ loop.index0 }}"
      - "traefik.http.services.{{ svc_name }}-{{ loop.index0 }}.loadbalancer.server.port={{ route.port }}"
{% if route.tls | default(false) %}
      - "traefik.http.routers.{{ svc_name }}-{{ loop.index0 }}.tls=true"
      - "traefik.http.routers.{{ svc_name }}-{{ loop.index0 }}.tls.certresolver=step-ca"
{% endif %}
{% endfor %}
{% elif svc.dns_name is defined %}
{% set fqdn = svc.dns_name ~ '.' ~ ansible_host %}
      - "traefik.http.routers.{{ svc_name }}.rule=Host(`{{ fqdn }}`)"
      - "traefik.http.routers.{{ svc_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ svc_name }}.tls=true"
      - "traefik.http.routers.{{ svc_name }}.tls.certresolver=step-ca"
      - "traefik.http.services.{{ svc_name }}.loadbalancer.server.port={{ svc.traefik.port }}"
{% elif svc.traefik.rule is defined %}
      - "traefik.http.routers.{{ svc_name }}.rule={{ svc.traefik.rule }}"
      - "traefik.http.routers.{{ svc_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ svc_name }}.tls=true"
      - "traefik.http.routers.{{ svc_name }}.tls.certresolver=step-ca"
      - "traefik.http.services.{{ svc_name }}.loadbalancer.server.port={{ svc.traefik.port }}"
{% endif %}
{% elif svc.traefik is not defined or svc.traefik == false %}
    labels:
      - "traefik.enable=false"
{% endif %}
{% endif %}

{% endfor %}
{% if 'traefik' in docker_compose_infra_services %}
volumes:
  traefik-certs:
{% endif %}
