#cloud-config
autoinstall:
  version: 1
  interactive-sections: [] # Fully automated, no prompts
  locale: en_US.UTF-8
  refresh-installer:
    update: no # Don't try to update the installer during boot (saves time/errors)

  packages:
    - openssh-server

  ssh:
    install-server: true
    allow-pw: true
    authorized-keys: ["{{ lookup('file', host_provision_ssh_pub_key_path) | trim }}"]

  # --- 1. Hostname ---
  identity:
    hostname: "{{ host_provision_hostname }}"
    username: "{{ ansible_user }}"
    password: "{{ ext_target_pass }}"
    realname: "{{ ansible_user }}"

  # --- 2. Network (Static IP) ---
  network:
    version: 2
    ethernets:
      eth0: # You might need to match this to your interface name (e.g., ens160)
        match:
          name: "e*"
        addresses:
{% for nic in host_provision_networks %}
          - {{ nic.ip }}/{{ nic.netmask }}
{% endfor %}
        routes:
          - to: default
            via: {{ host_provision_networks[0].gateway }}
        nameservers:
          addresses:
{% for dns in host_provision_dns_servers %}
            - {{ dns.server }}
{% endfor %}

  # --- 3. LVM Disk Structure (inventory-driven) ---
  # Macros to derive LV name and autoinstall IDs from mount path:
  #   /           -> lv_root  / lv-root  / format-root  / mount-root
  #   /var        -> lv_var   / lv-var   / format-var   / mount-var
  #   /opt/containers -> lv_opt_containers / lv-opt-containers / ...
{% macro lv_name(path) %}lv_{{ path | regex_replace('^/', '') | regex_replace('/', '_') | default('root', true) }}{% endmacro %}
{% macro lv_id(path) %}lv-{{ path | regex_replace('^/', '') | regex_replace('/', '-') | default('root', true) }}{% endmacro %}
{% macro format_id(path) %}format-{{ path | regex_replace('^/', '') | regex_replace('/', '-') | default('root', true) }}{% endmacro %}
{% macro mount_id(path) %}mount-{{ path | regex_replace('^/', '') | regex_replace('/', '-') | default('root', true) }}{% endmacro %}
  storage:
    config:
      # Disk and fixed partitions
      - {ptable: gpt, path: /dev/sda, preserve: false, name: '', grub_device: true, type: disk, id: disk-sda}
      - {device: disk-sda, size: 1024M, flag: bios_grub, number: 1, preserve: false, type: partition, id: partition-0}
      - {device: disk-sda, size: 2048M, flag: boot, number: 2, preserve: false, type: partition, id: partition-1}
      - {fstype: ext4, volume: partition-1, preserve: false, type: format, id: format-boot}
      - {device: disk-sda, size: -1, number: 3, preserve: false, type: partition, id: partition-2}
      # Volume Group
      - {name: vg_system, devices: [partition-2], preserve: false, type: lvm_volgroup, id: volgroup-0}
      # Logical Volumes
{% for mount in host_provision_lvm_mounts %}
      - {name: {{ lv_name(mount.path) }}, volgroup: volgroup-0, size: {{ mount.size_gb }}G, preserve: false, type: lvm_partition, id: {{ lv_id(mount.path) }}}
{% endfor %}
      # Format LVs
{% for mount in host_provision_lvm_mounts %}
      - {fstype: {{ mount.fstype | default('ext4') }}, volume: {{ lv_id(mount.path) }}, preserve: false, type: format, id: {{ format_id(mount.path) }}}
{% endfor %}
      # Mount points
      - {path: /boot, device: format-boot, type: mount, id: mount-boot}
{% for mount in host_provision_lvm_mounts %}
      - {path: {{ mount.path }}, device: {{ format_id(mount.path) }}, type: mount, id: {{ mount_id(mount.path) }}}
{% endfor %}

  # --- 4. Post-Install Commands ---
  late-commands:
    - curtin in-target -- apt update && apt full-upgrade -y && apt autoremove -y && poweroff
