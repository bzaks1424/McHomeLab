#!ipxe
# Auto-provision {{ inventory_hostname }} via netboot.xyz
# Generated by Ansible — do not edit manually
#
# This file is named by MAC address (mac-XX-XX-XX-XX-XX-XX.ipxe).
# netboot.xyz chains to it via boot.cfg — if the file exists, autoinstall runs.
# No MAC check needed here; the filename IS the gate.

:autoinstall
imgfree
set kernel-url {{ host_provision_pxe_kernel_url }}
set iso-url {{ host_provision_pxe_iso_url }}
set autoinstall-url {{ host_provision_pxe_base_url }}/autoinstall/{{ inventory_hostname }}/
set ds nocloud-net;s=${autoinstall-url}

kernel ${kernel-url}vmlinuz root=/dev/ram0 ramdisk_size=3500000 ip=dhcp url=${iso-url} cloud-config-url=/dev/null autoinstall ds=${ds} initrd=initrd
initrd ${kernel-url}initrd
boot
