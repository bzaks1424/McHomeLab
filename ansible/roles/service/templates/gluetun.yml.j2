{# Gluetun infrastructure service template #}
{% set gluetun = service_infra_services.gluetun %}
{% set config = gluetun.config %}
  gluetun:
    image: {{ gluetun_image }}
    restart: {{ gluetun.restart | default('unless-stopped') }}
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    environment:
      VPN_SERVICE_PROVIDER: "{{ config.vpn_provider }}"
      VPN_TYPE: "{{ config.vpn_type }}"
{% if config.vpn_type == "wireguard" %}
      WIREGUARD_PRIVATE_KEY: "{{ config.wireguard_private_key }}"
{% if config.wireguard_preshared_key is defined %}
      WIREGUARD_PRESHARED_KEY: "{{ config.wireguard_preshared_key }}"
{% endif %}
{% if config.wireguard_addresses is defined %}
      WIREGUARD_ADDRESSES: "{{ config.wireguard_addresses }}"
{% endif %}
{% else %}
      OPENVPN_USER: "{{ config.vpn_user }}"
      OPENVPN_PASSWORD: "{{ config.vpn_password }}"
{% endif %}
{% if config.server_countries is defined %}
      SERVER_COUNTRIES: "{{ config.server_countries }}"
{% endif %}
{% if config.server_names is defined %}
      SERVER_NAMES: "{{ config.server_names }}"
{% endif %}
      FIREWALL_OUTBOUND_SUBNETS: "{{ config.firewall_outbound_subnets }}"
{% if config.firewall_vpn_input_ports is defined %}
      FIREWALL_VPN_INPUT_PORTS: "{{ config.firewall_vpn_input_ports }}"
{% endif %}
{% if service_gluetun_tunneled | length > 0 %}
    labels:
      - "traefik.enable=true"
{% for tun_name, tun_svc in service_gluetun_tunneled.items() %}
{% if tun_svc.traefik is defined and tun_svc.traefik != false %}
{% if tun_svc.dns_name is defined %}
{% set fqdn = tun_svc.dns_name ~ '.' ~ ansible_host %}
      - "traefik.http.routers.{{ tun_name }}.rule=Host(`{{ fqdn }}`)"
{% elif tun_svc.traefik.rule is defined %}
      - "traefik.http.routers.{{ tun_name }}.rule={{ tun_svc.traefik.rule }}"
{% endif %}
      - "traefik.http.routers.{{ tun_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ tun_name }}.tls=true"
      - "traefik.http.routers.{{ tun_name }}.tls.certresolver={{ traefik_cert_resolver }}"
      - "traefik.http.services.{{ tun_name }}.loadbalancer.server.port={{ tun_svc.traefik.port }}"
{% if tun_svc.traefik.https_redirect | default(false) %}
{% if tun_svc.dns_name is defined %}
      - "traefik.http.routers.{{ tun_name }}-http.rule=Host(`{{ tun_svc.dns_name ~ '.' ~ ansible_host }}`)"
{% elif tun_svc.traefik.rule is defined %}
      - "traefik.http.routers.{{ tun_name }}-http.rule={{ tun_svc.traefik.rule }}"
{% endif %}
      - "traefik.http.routers.{{ tun_name }}-http.entrypoints=web"
      - "traefik.http.routers.{{ tun_name }}-http.middlewares={{ tun_name }}-redirect"
      - "traefik.http.middlewares.{{ tun_name }}-redirect.redirectscheme.scheme=https"
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
    healthcheck:
      test: ["CMD", "/gluetun-entrypoint", "healthcheck"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
