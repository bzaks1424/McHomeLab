# Generated by Ansible — do not edit manually
{% set config = service_infra_services.traefik.config %}
{% set passthrough_routes = config.external_routes | selectattr('passthrough', 'defined') | selectattr('passthrough') | list %}
{% set proxy_routes = config.external_routes | rejectattr('passthrough', 'defined') | list + config.external_routes | selectattr('passthrough', 'defined') | rejectattr('passthrough') | list %}
{% if passthrough_routes | length > 0 %}
tcp:
  routers:
{% for route in passthrough_routes %}
    {{ route.name }}:
      rule: "HostSNI(`{{ route.rule | regex_replace('.*Host\\(`([^`]+)`\\).*', '\\1') }}`)"
      entryPoints:
        - "{{ route.entrypoint | default('websecure') }}"
      service: "{{ route.name }}"
      tls:
        passthrough: true
{% endfor %}
  services:
{% for route in passthrough_routes %}
    {{ route.name }}:
      loadBalancer:
        servers:
          - address: "{{ route.url | regex_replace('^https?://', '') }}"
{% endfor %}
{% endif %}
{% set redirect_routes = proxy_routes | selectattr('https_redirect', 'defined') | selectattr('https_redirect') | list %}
{% if proxy_routes | length > 0 %}
http:
  routers:
{% for route in proxy_routes %}
    {{ route.name }}:
      rule: "{{ route.rule }}"
      entryPoints:
        - "{{ route.entrypoint | default('websecure') }}"
      service: "{{ route.name }}"
{% if route.entrypoint | default('websecure') != 'web' %}
      tls:
        certResolver: "{{ traefik_cert_resolver }}"
{% endif %}
{% endfor %}
{% for route in redirect_routes %}
    {{ route.name }}-http:
      rule: "{{ route.rule }}"
      entryPoints:
        - "web"
      middlewares:
        - "{{ route.name }}-redirect"
      service: "{{ route.name }}"
{% endfor %}
{% if redirect_routes | length > 0 %}
  middlewares:
{% for route in redirect_routes %}
    {{ route.name }}-redirect:
      redirectScheme:
        scheme: "https"
{% endfor %}
{% endif %}
  services:
{% for route in proxy_routes %}
    {{ route.name }}:
      loadBalancer:
        servers:
          - url: "{{ route.url }}"
{% endfor %}
{% endif %}