{# Traefik infrastructure service template #}
{% set traefik = service_infra_services.traefik %}
{% set config = traefik.config %}
{# Resolve CA cert host path: explicit config wins, else derive from co-located step-ca #}
{% if config.ca_cert_path is defined %}
{%   set ca_cert_host_path = config.ca_cert_path %}
{% elif 'step-ca' in service_services %}
{%   set ca_cert_host_path = service_services['step-ca'].volumes[0].split(':')[0] ~ '/certs/root_ca.crt' %}
{% endif %}
  traefik:
    image: traefik:latest
    restart: {{ traefik.restart | default('unless-stopped') }}
    command:
      - "--api.insecure=true"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
{% if config.external_routes is defined %}
      - "--providers.file.directory=/etc/traefik/dynamic"
{% endif %}
{% for ep_name, ep_port in config.entrypoints.items() %}
      - "--entrypoints.{{ ep_name }}.address=:{{ ep_port }}"
{% endfor %}
      - "--certificatesresolvers.step-ca.acme.caserver={{ config.acme_ca }}"
      - "--certificatesresolvers.step-ca.acme.email={{ config.acme_email }}"
      - "--certificatesresolvers.step-ca.acme.storage=/letsencrypt/acme.json"
      - "--certificatesresolvers.step-ca.acme.tlschallenge=true"
      - "--serversTransport.insecureSkipVerify=true"
      - "--ping=true"
    ports:
{% for ep_name, ep_port in config.entrypoints.items() %}
      - "{{ ep_port }}:{{ ep_port }}"
{% endfor %}
      - "9880:8080"
{% if ca_cert_host_path is defined %}
    environment:
      LEGO_CA_CERTIFICATES: "/etc/ssl/certs/step-ca-root.crt"
{% endif %}
{% if config.external_routes is defined %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
      - "{{ config.certs_volume }}:/letsencrypt"
{% if ca_cert_host_path is defined %}
      - "{{ ca_cert_host_path }}:/etc/ssl/certs/step-ca-root.crt:ro"
{% endif %}
{% if config.external_routes is defined %}
      - "{{ service_dir }}/traefik-external.yml:/etc/traefik/dynamic/external.yml:ro"
{% endif %}
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
{% if config.depends_on is defined %}
    depends_on:
{% for dep_name, dep_config in config.depends_on.items() %}
      {{ dep_name }}:
        condition: {{ dep_config.condition }}
{% endfor %}
{% endif %}
