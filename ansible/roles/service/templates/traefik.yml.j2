{# Traefik infrastructure service template #}
{% set traefik = service_infra_services.traefik %}
{% set config = traefik.config %}
{# Resolve CA cert host path from explicit config or import entry #}
{% if config.ca_cert_path is defined %}
{%   set ca_cert_host_path = config.ca_cert_path %}
{% endif %}
  traefik:
    image: {{ traefik_image }}
    restart: {{ traefik.restart | default('unless-stopped') }}
    command:
      - "--api.insecure=true"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
{% if config.external_routes is defined %}
      - "--providers.file.directory=/etc/traefik/dynamic"
{% endif %}
{% for ep_name, ep_port in config.entrypoints.items() %}
      - "--entrypoints.{{ ep_name }}.address=:{{ ep_port }}"
{% endfor %}
      - "--certificatesresolvers.{{ traefik_cert_resolver }}.acme.caserver={{ config.acme_ca }}"
      - "--certificatesresolvers.{{ traefik_cert_resolver }}.acme.email={{ config.acme_email }}"
      - "--certificatesresolvers.{{ traefik_cert_resolver }}.acme.storage=/letsencrypt/acme.json"
      - "--certificatesresolvers.{{ traefik_cert_resolver }}.acme.tlschallenge=true"
      - "--serversTransport.insecureSkipVerify=true"
      - "--ping=true"
    ports:
{% for ep_name, ep_port in config.entrypoints.items() %}
      - "{{ ep_port }}:{{ ep_port }}"
{% endfor %}
      - "{{ traefik_admin_port }}:8080"
{% if ca_cert_host_path is defined %}
    environment:
      LEGO_CA_CERTIFICATES: "{{ service_ca_cert_container_path }}"
{% endif %}
{% if config.external_routes is defined %}
    extra_hosts:
      - "{{ service_docker_host_gateway }}"
{% endif %}
    volumes:
      - "{{ service_docker_socket }}:{{ service_docker_socket }}:ro"
      - "{{ config.certs_volume }}:/letsencrypt"
{% if ca_cert_host_path is defined %}
      - "{{ ca_cert_host_path }}:{{ service_ca_cert_container_path }}:ro"
{% endif %}
{% if config.external_routes is defined %}
      - "{{ service_dir }}/traefik-external.yml:/etc/traefik/dynamic/external.yml:ro"
{% endif %}
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
{% if config.depends_on is defined %}
    depends_on:
{% for dep_name, dep_config in config.depends_on.items() %}
      {{ dep_name }}:
        condition: {{ dep_config.condition }}
{% endfor %}
{% endif %}
